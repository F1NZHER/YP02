<Window x:Class="ElectricityApp.EditAbonentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование абонента" 
        Height="380" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ФИО -->
        <TextBlock Grid.Row="0" 
                   Text="ФИО:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <TextBox Grid.Row="1" 
                 x:Name="txtFullName" 
                 Margin="0,0,0,15"
                 Padding="8"
                 Height="35"
                 FontSize="12"/>

        <!-- Адрес -->
        <TextBlock Grid.Row="2" 
                   Text="Адрес:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <TextBox Grid.Row="3" 
                 x:Name="txtAddress" 
                 Margin="0,0,0,15"
                 Padding="8"
                 Height="60"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="12"/>

        <!-- Тип местности -->
        <TextBlock Grid.Row="4" 
                   Text="Тип местности:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <ComboBox Grid.Row="5" 
                  x:Name="cmbLocality" 
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  Margin="0,0,0,20"
                  Height="30"
                  FontSize="12"
                  VerticalContentAlignment="Center"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button x:Name="btnSave" 
                    Content="Сохранить" 
                    Width="120" 
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Margin="0,0,10,0"
                    Click="btnSave_Click"/>

            <Button x:Name="btnCancel" 
                    Content="Отмена" 
                    Width="120" 
                    Height="40"
                    Background="#9E9E9E"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>