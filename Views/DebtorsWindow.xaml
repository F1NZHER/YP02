<Window x:Class="ElectricityApp.DebtorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список должников" 
        Height="400" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Таблица должников -->
        <DataGrid Grid.Row="0" 
                  x:Name="dgDebtors" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" 
                                    Binding="{Binding Id}" 
                                    Width="50"/>
                <DataGridTextColumn Header="Фамилия" 
                                    Binding="{Binding LastName}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Адрес" 
                                    Binding="{Binding Address}" 
                                    Width="200"/>
                <DataGridTextColumn Header="Последняя оплата" 
                                    Binding="{Binding LastPaymentDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="1" 
                x:Name="btnClose" 
                Content="Закрыть" 
                Width="100" 
                Height="30"
                HorizontalAlignment="Center"
                Background="#9E9E9E"
                Foreground="White"
                Click="btnClose_Click"/>
    </Grid>
</Window>