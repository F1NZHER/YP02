<Window x:Class="ElectricityApp.Views.AddPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Добавление платежа" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Новый платеж" 
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Абонент -->
        <TextBlock Grid.Row="1" Grid.Column="0" 
                   Text="Абонент:" 
                   VerticalAlignment="Center"
                   Margin="5"/>

        <ComboBox Grid.Row="1" Grid.Column="1" 
                  Name="cmbAbonent"
                  DisplayMemberPath="LastName"
                  SelectedValuePath="Id"
                  SelectionChanged="cmbAbonent_SelectionChanged"
                  Margin="5" Padding="5"/>

        <!-- Дата оплаты -->
        <TextBlock Grid.Row="2" Grid.Column="0" 
                   Text="Дата оплаты:" 
                   VerticalAlignment="Center"
                   Margin="5"/>

        <DatePicker Grid.Row="2" Grid.Column="1" 
                    Name="dpDate"
                    SelectedDate="{x:Static System:DateTime.Today}"
                    Margin="5"/>

        <!-- Предыдущие показания -->
        <TextBlock Grid.Row="3" Grid.Column="0" 
                   Text="Пред. показания:" 
                   VerticalAlignment="Center"
                   Margin="5"/>

        <TextBox Grid.Row="3" Grid.Column="1" 
                 Name="txtPrevValue"
                 Text="0"
                 Margin="5" Padding="5"
                 IsReadOnly="True"
                 Background="#F0F0F0"/>

        <!-- Текущие показания -->
        <TextBlock Grid.Row="4" Grid.Column="0" 
                   Text="Текущие показания:" 
                   VerticalAlignment="Center"
                   Margin="5"/>

        <TextBox Grid.Row="4" Grid.Column="1" 
                 Name="txtCurrentValue"
                 Margin="5" Padding="5"/>

        <!-- Тариф -->
        <TextBlock Grid.Row="5" Grid.Column="0" 
                   Text="Тариф (руб/кВт):" 
                   VerticalAlignment="Center"
                   Margin="5"/>

        <TextBox Grid.Row="5" Grid.Column="1" 
                 Name="txtTariff"
                 Text="5.0"
                 Margin="5" Padding="5"/>

        <!-- Результат -->
        <Border Grid.Row="6" Grid.ColumnSpan="2" 
                Background="#E8F5E9"
                CornerRadius="5"
                Margin="5"
                Padding="10">
            <TextBlock Name="tbResult" 
                       FontSize="14" 
                       FontWeight="Bold"
                       Foreground="#2E7D32"
                       HorizontalAlignment="Center"
                       Text="Выберите абонента и введите показания"/>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">

            <Button Name="btnCalculate" 
                    Content="Рассчитать" 
                    Click="btnCalculate_Click"
                    Width="120" Height="35" 
                    Margin="5"
                    Background="#2196F3" 
                    Foreground="White"
                    BorderThickness="0"/>

            <Button Name="btnSave" 
                    Content="Сохранить" 
                    Click="btnSave_Click"
                    Width="120" Height="35" 
                    Margin="5"
                    Background="#4CAF50" 
                    Foreground="White"
                    BorderThickness="0"
                    IsEnabled="False"/>

            <Button Name="btnCancel" 
                    Content="Отмена" 
                    Click="btnCancel_Click"
                    Width="120" Height="35" 
                    Margin="5"
                    Background="#F44336" 
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>