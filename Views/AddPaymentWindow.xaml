<Window x:Class="ElectricityApp.AddPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="Добавление платежа" 
        Height="480" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Абонент -->
        <TextBlock Grid.Row="0" 
                   Text="Абонент:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"/>

        <ComboBox Grid.Row="1" 
          x:Name="cmbAbonent" 
          DisplayMemberPath="LastName"
          SelectedValuePath="Id"
          SelectionChanged="cmbAbonent_SelectionChanged"
          Margin="0,0,0,15"
          Height="30"
          VerticalContentAlignment="Center"/>

        <!-- Дата платежа -->
        <TextBlock Grid.Row="2" 
                   Text="Дата платежа:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"/>

        <DatePicker Grid.Row="3" 
                    x:Name="dpDate" 
                    SelectedDate="{x:Static System:DateTime.Today}"
                    Margin="0,0,0,15"
                    Height="30"/>

        <!-- Предыдущие показания -->
        <TextBlock Grid.Row="4" 
                   Text="Предыдущие показания:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"/>

        <TextBox Grid.Row="5" 
                 x:Name="txtPrevValue" 
                 IsReadOnly="True"
                 Background="#F0F0F0"
                 Margin="0,0,0,15"
                 Padding="5"
                 Height="30"/>

        <!-- Текущие показания и тариф -->
        <Grid Grid.Row="6" Margin="0,0,0,95">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Текущие показания:" 
                           Margin="0,0,0,5"
                           FontWeight="Bold"/>
                <TextBox x:Name="txtCurrentValue" 
                         Margin="0,0,0,15"
                         Padding="5"
                         Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Тариф (руб./кВт·ч):" 
                           Margin="0,0,0,5"
                           FontWeight="Bold"/>
                <TextBox x:Name="txtTariff" 
                         Text="5.0"
                         Margin="0,0,0,15"
                         Padding="5"
                         Height="30"/>
            </StackPanel>
        </Grid>

        <!-- Результат расчета -->
        <TextBlock Grid.Row="6" 
                   x:Name="tbResult" 
                   Text="Сумма к оплате: 0.00 руб."
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,67,0,20"
                   Foreground="#2196F3" Grid.RowSpan="2"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="btnCalculate" 
                    Content="Рассчитать" 
                    Width="140" 
                    Height="40"
                    Background="#2196F3"
                    Foreground="White"
                    Margin="0,0,15,0"
                    Click="btnCalculate_Click"/>

            <Button x:Name="btnSave" 
                    Content="Сохранить" 
                    Width="140" 
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    Margin="0,0,15,0"
                    IsEnabled="False"
                    Click="btnSave_Click"/>

            <Button x:Name="btnCancel" 
                    Content="Отмена" 
                    Width="120" 
                    Height="40"
                    Background="#F44336"
                    Foreground="White"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>