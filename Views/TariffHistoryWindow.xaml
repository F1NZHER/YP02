<Window x:Class="ElectricityApp.TariffHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История тарифов" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="История изменения тарифов" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" 
                  x:Name="dgTariffHistory" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Тариф (руб./кВт·ч)" 
                                    Binding="{Binding Rate, StringFormat={}{0:F2}}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Действует с" 
                                    Binding="{Binding ValidFrom, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Действует по" 
                                    Binding="{Binding ValidTo, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Изменил" Binding="{Binding ChangedBy}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Закрыть" Width="120" Height="35" 
                HorizontalAlignment="Center" Background="#9E9E9E" Foreground="White"
                Click="btnClose_Click"/>
    </Grid>
</Window>