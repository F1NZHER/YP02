<Window x:Class="ElectricityApp.EditLocalityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование типа местности" 
        Height="380" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Название -->
        <TextBlock Grid.Row="0" 
                   Text="Название:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <TextBox Grid.Row="1" 
                 x:Name="txtName" 
                 Margin="0,0,0,15"
                 Padding="8"
                 Height="35"
                 FontSize="12"/>

        <!-- Коэффициент тарифа -->
        <TextBlock Grid.Row="2" 
                   Text="Коэффициент тарифа:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <TextBox Grid.Row="3" 
                 x:Name="txtCoefficient" 
                 Margin="0,0,0,15"
                 Padding="8"
                 Height="35"
                 FontSize="12"
                 HorizontalContentAlignment="Right"/>

        <TextBlock Grid.Row="4" 
                   Text="Пример: 0.8 (скидка 20%), 1.0 (базовый), 0.7 (скидка 30%)" 
                   Margin="0,0,0,20"
                   FontSize="10"
                   Foreground="Gray"/>

        <!-- Регион -->
        <TextBlock Grid.Row="5" 
                   Text="Регион:" 
                   Margin="0,0,0,5"
                   FontWeight="Bold"
                   FontSize="12"/>

        <TextBox Grid.Row="6" 
                 x:Name="txtRegion" 
                 Margin="0,0,0,20"
                 Padding="8"
                 Height="35"
                 FontSize="12"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button x:Name="btnSave" 
                    Content="Сохранить" 
                    Width="120" 
                    Height="40"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Margin="0,0,10,0"
                    Click="btnSave_Click"/>

            <Button x:Name="btnCancel" 
                    Content="Отмена" 
                    Width="120" 
                    Height="40"
                    Background="#9E9E9E"
                    Foreground="White"
                    FontSize="12"
                    FontWeight="Bold"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>